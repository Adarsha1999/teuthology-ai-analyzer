# =============================================================================
# Teuthology AI — backend environment
# Copy to backend/.env:  cp backend/.env.example backend/.env
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Teuthology AI Analyzer"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
# Default: PostgreSQL (production)
DATABASE_URL=postgresql://teuth:teuth123@localhost:5432/teuthology_ai
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Dev/test: SQLite (uncomment below, comment above)
# DATABASE_URL=sqlite:///./data/teuthology.db

# ── API Authentication ───────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Set in frontend env as VITE_API_KEY to pass X-API-Key header automatically.
# Leave empty to disable auth (dev only).
API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── External services ─────────────────────────────────────────────────────────
PULPITO_BASE=https://pulpito.ceph.com
TEUTH_ARCHIVE_BASE=https://qa-proxy.ceph.com/teuthology
HTTP_TIMEOUT_S=120

# ── Log processing ────────────────────────────────────────────────────────────
MAX_LOG_BYTES=1500000
MAX_DIGEST_CHARS=24000

# ── LLM defaults ──────────────────────────────────────────────────────────────
LLM_DEFAULT_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_REQUEST_TIMEOUT=600

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# Cursor
# CURSOR_API_KEY=crsr_...
# CURSOR_MODEL=composer-2

# IBM Bob Shell
# BOBSHELL_API_KEY=...
# IBM_BOB_ENABLED=true
# IBM_BOB_COMMAND=bob
# IBM_BOB_WORKDIR=/path/to/trusted/workspace
# IBM_BOB_TIMEOUT_SECONDS=600
# IBM_BOB_INPUT_MODE=prompt_file
# IBM_BOB_EXTRA_ARGS="--auth-method api-key"
